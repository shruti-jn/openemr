{#
AgentForge AI Chat Widget – Patient Demographics Card

Embeds the AgentForge chat UI as an iframe on the patient demographics page.
The iframe loads the React frontend in embed mode, scoped to the current patient's pid.
The service runs from the agentforge-openemr sister directory.

@package   OpenEMR
@license   https://github.com/openemr/openemr/blob/master/LICENSE GNU General Public License 3
#}

{% extends "patient/card/card_base.html.twig" %}

{% block content %}
<div class="agentforge-chat-widget p-1">
    <div class="mb-2 small text-muted">
        <i class="fa fa-robot"></i>
        {{ "Ask questions about this patient's records, medications, and appointments."|xlt }}
    </div>
    <iframe
        id="agentforge-chat-frame"
        src="{{ embedUrl|attr }}"
        style="width: 100%; height: {{ iframeHeight }}px; border: 1px solid #dee2e6; border-radius: 4px;"
        title="{{ "AI Assistant"|xlt }}"
        loading="lazy"
        sandbox="allow-scripts allow-same-origin allow-forms"
    ></iframe>
    <div class="mt-1 small text-muted text-right">
        <a href="{{ newWindowUrl|attr }}" target="_blank" rel="noopener noreferrer">
            <i class="fa fa-external-link-alt"></i> {{ "Open in new window"|xlt }}
        </a>
    </div>
</div>
{% endblock %}
